{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["CONSTRUKT_KIT_STORYBOOK_BASE_PATH"],
      "outputs": ["dist/**", "storybook-static/**"]
    },
    "check:exports": {
      "dependsOn": ["build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "lint:fix": {
      "dependsOn": ["^build"]
    },
    "format": {},
    "storybook": {
      "dependsOn": ["^build"],
      "persistent": true
    }
  }
}
