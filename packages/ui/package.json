{
  "name": "@b3/ui",
  "version": "1.0.0",
  "private": false,
  "description": "Shared component library for B3 frontend apps",
  "author": "Vasil Rimar",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./preset": {
      "import": {
        "types": "./dist/preset.d.mts",
        "default": "./dist/preset.mjs"
      },
      "require": {
        "types": "./dist/preset.d.cts",
        "default": "./dist/preset.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "panda codegen",
    "build": "panda codegen && tsdown",
    "dev": "panda codegen && tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint -c .oxlintrc.json src",
    "format": "oxfmt src -c ../config/oxfmt/index.jsonc",
    "test": "vitest run"
  },
  "dependencies": {
    "@ark-ui/react": "^5.34.1",
    "@b3/utils": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.19",
    "dayjs": "^1.11.19",
    "lucide-react": "^0.577.0",
    "react-resizable-panels": "^4.7.1",
    "react-use": "^17.6.0",
    "ts-pattern": "^5.9.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@b3/config": "workspace:*",
    "@pandacss/dev": "^1.9.0",
    "@pandacss/eslint-plugin": "^0.3.2",
    "@storybook/react-vite": "^10.2.19",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.21.2",
    "vitest": "^4.0.18"
  }
}
