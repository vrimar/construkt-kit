{
  "name": "@b3/ui",
  "version": "0.0.1",
  "private": false,
  "description": "Shared component library for B3 frontend apps",
  "author": "Vasil Rimar",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./preset": {
      "import": {
        "types": "./dist/preset.d.mts",
        "default": "./dist/preset.mjs"
      },
      "require": {
        "types": "./dist/preset.d.cts",
        "default": "./dist/preset.cjs"
      }
    },
    "./panda.buildinfo.json": "./dist/panda.buildinfo.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "pnpm --filter @b3/styled-system build",
    "build": "pnpm --filter @b3/styled-system build && tsdown && panda ship --outfile dist/panda.buildinfo.json",
    "dev": "pnpm --filter @b3/styled-system build && tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "test": "vitest run"
  },
  "dependencies": {
    "@ark-ui/react": "^5.36.1",
    "@b3/preset": "workspace:*",
    "@b3/styled-system": "workspace:*",
    "@b3/utils": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "dayjs": "^1.11.20",
    "lucide-react": "^1.8.0",
    "react-resizable-panels": "^4.10.0",
    "react-use": "^17.6.0",
    "ts-pattern": "^5.9.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@b3/config": "workspace:*",
    "@pandacss/dev": "^1.10.0",
    "@pandacss/eslint-plugin": "^0.3.2",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsdown": "^0.21.9",
    "vitest": "^4.1.5"
  }
}
