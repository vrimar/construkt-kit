{
  "name": "@construkt-kit/ui",
  "version": "0.1.3",
  "private": false,
  "description": "Shared component library for Construkt Kit frontend apps",
  "author": "Vasil Rimar",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "default": "./dist/index.cjs"
      }
    },
    "./preset": {
      "import": {
        "types": "./dist/preset.d.mts",
        "default": "./dist/preset.mjs"
      },
      "require": {
        "types": "./dist/preset.d.cts",
        "default": "./dist/preset.cjs"
      }
    },
    "./panda.buildinfo.json": "./dist/panda.buildinfo.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "pnpm --filter @construkt-kit/styled-system build",
    "build": "tsdown && panda ship --outfile dist/panda.buildinfo.json",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "test": "vitest run"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@construkt-kit/preset": "workspace:*",
    "@construkt-kit/styled-system": "workspace:*",
    "@construkt-kit/utils": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "dayjs": "^1.11.21",
    "lucide-react": "^1.20.0",
    "react-resizable-panels": "^4.11.2",
    "react-use": "^17.6.1",
    "ts-pattern": "^5.9.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@construkt-kit/config": "workspace:*",
    "@pandacss/dev": "^1.11.3",
    "@pandacss/eslint-plugin": "^0.3.2",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  }
}
