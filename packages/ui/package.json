{
  "name": "@construkt-kit/ui",
  "version": "0.3.0",
  "private": false,
  "description": "Shared component library for Construkt Kit frontend apps",
  "author": "Vasil Rimar",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vrimar/construkt-kit.git",
    "directory": "packages/ui"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./preset": {
      "types": "./dist/preset.d.mts",
      "default": "./dist/preset.mjs"
    },
    "./panda": {
      "types": "./dist/panda.d.mts",
      "default": "./dist/panda.mjs"
    },
    "./panda.buildinfo.json": "./dist/panda.buildinfo.json"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "pnpm --filter @construkt-kit/styled-system build",
    "build": "tsdown && panda ship --outfile dist/panda.buildinfo.json",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "test": "vitest run",
    "check:exports": "publint --strict && attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@construkt-kit/utils": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "dayjs": "^1.11.21",
    "lucide-react": "^1.23.0",
    "react-resizable-panels": "^4.12.0",
    "react-use": "^17.6.1",
    "ts-pattern": "^5.9.0"
  },
  "peerDependencies": {
    "@construkt-kit/preset": ">=0.2.0",
    "@pandacss/dev": "^1.11.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@construkt-kit/config": "workspace:*",
    "@construkt-kit/preset": "workspace:*",
    "@construkt-kit/styled-system": "workspace:*",
    "@pandacss/dev": "^1.11.4",
    "@pandacss/eslint-plugin": "^0.3.2",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  }
}
