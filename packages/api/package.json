{
  "name": "@construkt-kit/api",
  "version": "0.2.0",
  "private": false,
  "description": "HTTP client, query factories, typed errors, and generated API types for Construkt Kit apps",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vrimar/construkt-kit.git",
    "directory": "packages/api"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "check:exports": "publint --strict && attw --pack . --profile esm-only"
  },
  "bin": {
    "construkt-kit-api-gen": "./bin/api-gen.mjs"
  },
  "dependencies": {
    "@kubb/core": "^4.39.2",
    "@kubb/plugin-client": "^4.39.2",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@construkt-kit/config": "workspace:*",
    "tsdown": "^0.22.3"
  }
}
