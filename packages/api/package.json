{
  "name": "@b3/api",
  "version": "0.0.1",
  "private": false,
  "description": "HTTP client, query factories, typed errors, and generated API types for B3 apps",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src"
  },
  "bin": {
    "b3-api-gen": "./bin/api-gen.mjs"
  },
  "dependencies": {
    "@kubb/core": "^4.37.2",
    "@kubb/plugin-client": "^4.37.2",
    "tsx": "^4"
  },
  "devDependencies": {
    "@b3/config": "workspace:*",
    "tsdown": "^0.21.9"
  }
}
