{
  "name": "@b3/api",
  "version": "0.0.1",
  "private": false,
  "description": "HTTP client, query factories, typed errors, and generated API types for B3 apps",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt src -c ../config/oxfmt/index.jsonc",
    "generate": "orval --config orval.config.ts"
  },
  "bin": {
    "b3-gen-api": "./bin/gen-api.mjs"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@kubb/core": "^4.31.5",
    "@kubb/plugin-client": "^4.31.5",
    "tsx": "^4"
  },
  "devDependencies": {
    "@b3/config": "workspace:*",
    "tsup": "^8.5.1"
  }
}
