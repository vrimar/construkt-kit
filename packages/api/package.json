{
  "name": "@b3/api",
  "version": "0.0.1",
  "private": false,
  "description": "HTTP client, query factories, typed errors, and generated API types for B3 apps",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt src -c ../config/oxfmt/index.jsonc",
    "generate": "orval --config orval.config.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "ky": "^1.14.3"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@b3/config": "workspace:*",
    "orval": "^8.5.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
