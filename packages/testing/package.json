{
  "name": "@construkt-kit/testing",
  "version": "0.0.1",
  "private": false,
  "description": "Shared test utilities — custom render, MSW handlers — for Construkt Kit apps (devDependency only)",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./handlers": {
      "import": {
        "types": "./dist/handlers/index.d.mts",
        "default": "./dist/handlers/index.mjs"
      },
      "require": {
        "types": "./dist/handlers/index.d.cts",
        "default": "./dist/handlers/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "@testing-library/react": "^16.3.2",
    "msw": "~2.13.4"
  },
  "devDependencies": {
    "@construkt-kit/config": "workspace:*",
    "@construkt-kit/ui": "workspace:*",
    "tsdown": "^0.21.9"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
