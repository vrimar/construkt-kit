{
  "name": "@b3/utils",
  "version": "0.0.1",
  "private": false,
  "description": "Stateless, framework-agnostic utilities for B3 frontend apps",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt src"
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@b3/config": "workspace:*",
    "tsdown": "^0.21.7"
  }
}
