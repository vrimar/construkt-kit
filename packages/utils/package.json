{
  "name": "@construkt-kit/utils",
  "version": "0.1.3",
  "private": false,
  "description": "Stateless, framework-agnostic utilities for Construkt Kit frontend apps",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src"
  },
  "dependencies": {
    "dayjs": "^1.11.21",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@construkt-kit/config": "workspace:*",
    "tsdown": "^0.22.3"
  }
}
