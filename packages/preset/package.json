{
  "name": "@construkt-kit/preset",
  "version": "0.0.1",
  "private": false,
  "description": "Shared Panda CSS preset for Construkt Kit frontend apps",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src"
  },
  "dependencies": {
    "@ark-ui/react": "^5.36.1"
  },
  "devDependencies": {
    "@construkt-kit/config": "workspace:*",
    "@pandacss/dev": "^1.10.0",
    "tsdown": "^0.21.9"
  }
}
