{
  "name": "@construkt-kit/preset",
  "version": "0.2.0",
  "private": false,
  "description": "Shared Panda CSS preset for Construkt Kit frontend apps",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2"
  },
  "devDependencies": {
    "@construkt-kit/config": "workspace:*",
    "@pandacss/dev": "^1.11.4",
    "tsdown": "^0.22.3"
  }
}
