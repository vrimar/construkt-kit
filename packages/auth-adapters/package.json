{
  "name": "@b3/auth-adapters",
  "version": "0.0.1",
  "private": false,
  "description": "Pre-built AuthProvider adapter implementations for Auth0",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./auth0": {
      "import": {
        "types": "./dist/auth0.d.mts",
        "default": "./dist/auth0.mjs"
      },
      "require": {
        "types": "./dist/auth0.d.cts",
        "default": "./dist/auth0.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt src -c ../config/oxfmt/index.jsonc"
  },
  "peerDependencies": {
    "@auth0/auth0-react": ">=2.0.0",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@auth0/auth0-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@auth0/auth0-react": "^2.16.1",
    "@b3/config": "workspace:*",
    "@b3/pages": "workspace:*",
    "tsdown": "^0.21.7"
  }
}
