{
  "name": "@construkt-kit/auth-adapters",
  "version": "0.1.1",
  "private": false,
  "description": "Pre-built AuthProvider adapter implementations for Auth0",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./auth0": {
      "import": {
        "types": "./dist/auth0.d.mts",
        "default": "./dist/auth0.mjs"
      },
      "require": {
        "types": "./dist/auth0.d.cts",
        "default": "./dist/auth0.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@auth0/auth0-react": "^2.16.2",
    "@construkt-kit/config": "workspace:*",
    "@construkt-kit/pages": "workspace:*",
    "tsdown": "^0.21.9"
  }
}
