{
  "name": "@b3/auth-adapters",
  "version": "0.0.1",
  "private": false,
  "description": "Pre-built AuthProvider adapter implementations for Auth0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./auth0": {
      "import": "./dist/auth0.js",
      "require": "./dist/auth0.cjs",
      "types": "./dist/auth0.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt src -c ../config/oxfmt/index.jsonc"
  },
  "peerDependencies": {
    "@auth0/auth0-react": ">=2.0.0",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@auth0/auth0-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@auth0/auth0-react": "^2.15.0",
    "@b3/config": "workspace:*",
    "@b3/pages": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
