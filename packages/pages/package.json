{
  "name": "@construkt-kit/pages",
  "version": "0.1.2",
  "private": false,
  "description": "Shared full-page components (login, register, forgot password) for Construkt Kit apps",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vrimar/construkt-kit.git",
    "directory": "packages/pages"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "check:exports": "publint --strict && attw --pack . --profile esm-only"
  },
  "peerDependencies": {
    "@construkt-kit/ui": ">=0.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@construkt-kit/config": "workspace:*",
    "@construkt-kit/ui": "workspace:*",
    "@storybook/react-vite": "^10.4.6",
    "@types/react": "^19.2.17",
    "storybook": "^10.4.6",
    "tsdown": "^0.22.3"
  }
}
