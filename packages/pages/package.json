{
  "name": "@construkt-kit/pages",
  "version": "0.1.2",
  "private": false,
  "description": "Shared full-page components (login, register, forgot password) for Construkt Kit apps",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src"
  },
  "peerDependencies": {
    "@construkt-kit/ui": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@construkt-kit/config": "workspace:*",
    "@construkt-kit/ui": "workspace:*",
    "@storybook/react": "^10.4.6",
    "@types/react": "^19.2.17",
    "storybook": "^10.4.6",
    "tsdown": "^0.22.3"
  }
}
