{
  "name": "@b3/pages",
  "version": "0.0.1",
  "private": false,
  "description": "Shared full-page components (login, register, forgot password) for B3 apps",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint src",
    "format": "oxfmt src -c ../config/oxfmt/index.jsonc"
  },
  "peerDependencies": {
    "@b3/ui": "workspace:*",
    "@chakra-ui/react": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@b3/config": "workspace:*",
    "@b3/ui": "workspace:*",
    "@storybook/react": "^10.2.15",
    "@storybook/test": "^8.6.17",
    "@types/react": "^19.2.14",
    "storybook": "^10.2.15",
    "tsup": "^8.5.1"
  }
}
