{
  "name": "@construkt-kit/config",
  "version": "0.1.3",
  "description": "Shared tool configuration for all Construkt Kit frontend projects",
  "type": "module",
  "exports": {
    "./typescript": "./typescript/base.json",
    "./vite": {
      "import": {
        "types": "./dist/vite/index.d.mts",
        "default": "./dist/vite/index.mjs"
      },
      "require": {
        "default": "./dist/vite/index.cjs"
      }
    },
    "./playwright": {
      "import": {
        "types": "./dist/playwright/index.d.mts",
        "default": "./dist/playwright/index.mjs"
      },
      "require": {
        "types": "./dist/playwright/index.d.cts",
        "default": "./dist/playwright/index.cjs"
      }
    },
    "./kubb": {
      "import": {
        "types": "./dist/kubb/index.d.mts",
        "default": "./dist/kubb/index.mjs"
      },
      "require": {
        "types": "./dist/kubb/index.d.cts",
        "default": "./dist/kubb/index.cjs"
      }
    },
    "./oxlint": {
      "import": {
        "types": "./dist/oxlint/index.d.mts",
        "default": "./dist/oxlint/index.mjs"
      },
      "require": {
        "types": "./dist/oxlint/index.d.cts",
        "default": "./dist/oxlint/index.cjs"
      }
    },
    "./oxfmt": {
      "import": {
        "types": "./dist/oxfmt/index.d.mts",
        "default": "./dist/oxfmt/index.mjs"
      },
      "require": {
        "types": "./dist/oxfmt/index.d.cts",
        "default": "./dist/oxfmt/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "typescript"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "tsdown": "^0.22.3"
  },
  "dependencies": {
    "@kubb/core": "^4.39.2",
    "@kubb/plugin-client": "^4.39.2",
    "@kubb/plugin-oas": "^4.39.2",
    "@kubb/plugin-react-query": "^4.39.2",
    "@kubb/plugin-ts": "^4.39.2",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^6.0.3",
    "vite": "^8.1.2",
    "vite-plugin-checker": "^0.14.4"
  },
  "peerDependencies": {
    "oxfmt": "^0.55.0",
    "oxlint": "^1.61.0"
  }
}
