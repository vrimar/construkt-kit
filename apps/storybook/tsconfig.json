{
  "extends": "@construct-kit/config/typescript",
  "compilerOptions": {
    "paths": {
      "*": ["./*"],
      "@construct-kit/preset": ["../../packages/preset/src/index.ts"],
      "@construct-kit/styled-system/*": ["../../packages/styled-system/dist/*"],
      "@storybook/react-vite": ["./node_modules/@storybook/react-vite"],
      "storybook/test": ["./node_modules/storybook/test"],
      "@construct-kit/ui": ["../../packages/ui/src/index.ts"],
      "@construct-kit/pages": ["../../packages/pages/src/index.ts"]
    }
  },
  "include": [
    ".storybook/**/*.d.ts",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "../../packages/ui/src/**/*.stories.ts",
    "../../packages/ui/src/**/*.stories.tsx",
    "../../packages/pages/src/**/*.stories.ts",
    "../../packages/pages/src/**/*.stories.tsx"
  ]
}
