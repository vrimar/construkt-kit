{
  "name": "construkt-kit",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "storybook": "pnpm --filter @construkt-kit/storybook storybook",
    "build-storybook": "pnpm --filter @construkt-kit/storybook build",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "dotenv -e .env -- changeset publish",
    "publish-local": "dotenv -e .env -- pnpm -r publish --access public",
    "update-deps": "pnpm update -r && pnpm update"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@construkt-kit/config": "workspace:*",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "dotenv-cli": "^11.0.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "turbo": "^2.9.6"
  },
  "engines": {
    "node": ">=22.18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0"
}
