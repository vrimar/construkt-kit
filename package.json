{
  "name": "b3-frontend-shared",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "storybook": "pnpm --filter @b3/storybook storybook",
    "build-storybook": "pnpm --filter @b3/storybook build",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "changeset publish",
    "update-deps": "pnpm update -r && pnpm update"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@typescript/native-preview": "7.0.0-dev.20260407.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "turbo": "^2.9.5"
  },
  "engines": {
    "node": ">=22.18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0"
}
